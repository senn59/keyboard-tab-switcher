{
  "manifest_version": 3,
  "name": "Keyboard tab switcher",
  "version": "0.1",

  "description": "Use the keyboard to navigate between your tabs easily.",

  "permissions": ["activeTab", "tabs", "commands"],
  "web_accessible_resources": [
      {
          "resources": ["menu.html"],
          "matches": ["<all_urls>"]
      }
  ],

  "commands": {
      "open-switcher": {
          "suggested_key": {
              "default": "Ctrl+Space"
          }
      }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": { 
      "scripts": ["background.js"] 
  }
}
